# =====================================================================
# .env.example — Plantilla de variables de entorno para el CRM Dekoor
# =====================================================================
# Copia este archivo a `.env` y rellena los valores reales.
# NUNCA subas el `.env` real a git (ya esta en .gitignore).
#
# Para Render: estas mismas variables se configuran en
# Dashboard > Service > Environment.
# =====================================================================


# --- Servidor ---
PORT=3000                                     # Opcional. Default: 3000
API_URL=https://app.dekoormx.com              # Dominio publico (back_urls MP, notification_url, etc)


# --- Firebase (REQUERIDO) ---
# JSON completo de la service account, en una sola linea.
# Se obtiene en: Firebase Console > Project Settings > Service accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}


# --- Mercado Pago (REQUERIDO para checkout) ---
# Token de acceso de la app. APP_USR-... para test y prod.
# Dashboard > Tus integraciones > Tu app > Credenciales
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxx
# Clave secreta del webhook (verifica firma HMAC).
# Dashboard > Tus integraciones > Tu app > Webhooks > Configurar notificaciones
MP_WEBHOOK_SECRET=
# true cuando uses credenciales TEST (TESTUSER). false en produccion.
MP_SANDBOX=false


# --- WhatsApp Cloud API ---
VERIFY_TOKEN=                                 # Token que verifica el webhook con Meta
WHATSAPP_TOKEN=                               # Bearer token del numero
PHONE_NUMBER_ID=                              # ID del numero de WhatsApp
WHATSAPP_BUSINESS_ACCOUNT_ID=                 # ID del WABA


# --- Meta / Facebook (Graph API, Pixel, Pages) ---
META_GRAPH_TOKEN=                             # Token de sistema con permisos de Graph
META_ADS_TOKEN=                               # Token para Marketing API (opcional, fallback a META_GRAPH_TOKEN)
META_PIXEL_ID=                                # ID del Pixel para CAPI
META_CAPI_ACCESS_TOKEN=                       # Token Conversions API
FB_PAGE_ID=                                   # ID de la pagina de Facebook
FB_PAGE_ACCESS_TOKEN=                         # Page access token


# --- Gemini / Google AI ---
GEMINI_API_KEY=                               # API key de Gemini (texto/chat)
GOOGLE_AI_IMAGE_KEY=                          # API key para generacion de imagenes (mockups)


# --- Google Sheets ---
# JSON completo de credenciales de service account de Google Sheets API
GOOGLE_SHEETS_CREDENTIALS_JSON=


# --- Google Photos (auto-post) ---
GOOGLE_PHOTOS_CLIENT_ID=
GOOGLE_PHOTOS_CLIENT_SECRET=
GOOGLE_PHOTOS_REDIRECT_URI=
AUTOPOST_ALBUM_ID=                            # ID del album de Google Photos a publicar


# --- Skydropx (paqueteria) ---
SKYDROPX_CLIENT_ID=
SKYDROPX_CLIENT_SECRET=
SKYDROPX_ZIP_ORIGIN=34188                     # CP de origen


# --- J&T Express ---
# Opción 1: JSON único (recomendado para Render)
JT_CONFIG_JSON={"apiAccount":"...","privateKey":"...","customerCode":"...","password":"...","useTest":"false","sender":{"name":"Dekoor MX","phone":"6181333519","state":"Durango","city":"Durango","area":"Azteca","address":"Hilario Moreno 206","zip":"34190"}}
# Opción 2: variables individuales (se usan si JT_CONFIG_JSON no existe)
# JT_API_ACCOUNT=
# JT_PRIVATE_KEY=
# JT_CUSTOMER_CODE=
# JT_PASSWORD=
# JT_USE_TEST=false
# JT_SENDER_NAME=Dekoor MX
# JT_SENDER_PHONE=6181333519
# JT_SENDER_STATE=Durango
# JT_SENDER_CITY=Durango
# JT_SENDER_AREA=Azteca
# JT_SENDER_ADDRESS=Hilario Moreno 206
# JT_SENDER_ZIP=34190


# --- Auto-post Facebook ---
AUTOPOST_ENABLED=false
AUTOPOST_CRON=0 9,12,15,18,21 * * *           # Horarios de publicacion
FBG_PHOTOS_FOLDER=C:/Users/chris/Pictures/IA AQ/Grupo
FBG_GROUP_NAME=Mujer-ON
FBG_PAGE_NAME=AQ Decoraciones


# --- Auto-post WhatsApp Group ---
WA_GROUP_ENABLED=false
WA_GROUP_CRON=0 11 * * *
WA_PHOTOS_FOLDER=C:/Users/chris/Pictures/IA Dekoor/Grupo
WA_GROUP_NAME=Referencias Dekoor
WA_CHROME_PROFILE=Profile 2


# --- Laser MeerK40t (solo local) ---
MEERK40T_HOST=127.0.0.1
MEERK40T_PORT=2323
MEERK40T_ENABLED=                             # Setear en Render para forzar conexion (no recomendado)
