rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // PS Editor projects
    match /ps_projects/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Everything else - default deny
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
